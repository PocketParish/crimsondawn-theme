#c80000","checkout_error_color":"#ff0000","sections":{"header":{"type":"header","settings":{"align_logo":"center","logo":"shopify:\/\/shop_images\/header-3_751e45ae-4ea0-428b-afa5-4e37f38b69f6.jpg","logo_max_width":140,"main_linklist":"main-menu","message":true,"home_page_only":true,"message_text":"Free shipping to the lower 48 for orders $75 and up!","message_link":"shopify:\/\/pages\/shipping-info","color_bg":"#a90000","color_text":"#ffffff"}},"hero":{"type":"hero","disabled":true,"settings":{"image":"shopify:\/\/shop_images\/CDmay4thsale-pixelupdate.png","alignment":"center","hero_layout":"full_width","hero_size":"adapt","text_size":"large","title":"","text":"","button_label":"","button_link":""}},"slideshow":{"type":"slideshow","blocks":{"slideshow-0":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/16.jpg","alignment":"center center","slide_title":"","subheading":"","button_label":""}},"slideshow-1":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/12.jpg","alignment":"center center","slide_title":"","subheading":"","button_label":""}},"1569183972538":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/13.jpg","alignment":"center center","slide_title":"","subheading":"","button_label":""}},"1569624576569":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/15.jpg","alignment":"center center","slide_title":"","subheading":"","button_label":""}},"1569624615288":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/14.jpg","alignment":"center center","slide_title":"","subheading":"","button_label":""}}},"block_order":["slideshow-0","slideshow-1","1569183972538","1569624576569","1569624615288"],"disabled":true,"settings":{"slideshow_height":"adapt","text_size":"medium","text_alignment":"center center","show_overlay":false,"autorotate":true,"autorotate_speed":3}},"footer":{"type":"footer","blocks":{"link_list":{"type":"link_list","settings":{"title":"Quick links","menu":"footer"}},"text":{"type":"text","settings":{"title":"A Little Bit About Us","text":"<p>We&#x27;re just a bunch of Sci Fi nerds in Texas that have a passion for sabers. We&#x27;re able to do this for a living because of people like YOU, which is why we will go to extreme lengths to make your experience the best! Join Crimson Dawn® and see for yourself!<\/p>"}},"newsletter":{"type":"newsletter","settings":{"title":"Subscribe for news and updates on new saber models, sales, and be alerted when lightsabers come back in stock!"}},"1571075135824":{"type":"text","settings":{"title":"Our com channels are open!","text":"<p><a href=\"\/pages\/contact-us\" title=\"Contact Us\">Contact Us <\/a><\/p>"}}},"block_order":["link_list","text","newsletter","1571075135824"],"settings":{"show_payment_icons":true,"color_footer_bg":"#000000","color_footer_text":"#ffffff"}},"collection-template":{"type":"collection-template","settings":{"layout":"grid","grid":5,"rows":8,"show_collection_image":true,"show_vendor":true,"sort_enable":true,"tags_enable":false}},"cart-template":{"type":"cart-template","settings":{"cart_ajax_enable":true,"cart_notes_enable":true}},"product-template":{"type":"product-template","settings":{"image_size":"medium","show_quantity_selector":true,"show_variant_labels":true,"show_vendor":false,"enable_zoom":true,"enable_payment_button":false,"show_share_buttons":true}},"product-recommendations":{"type":"product-recommendations","settings":{"show_product_recommendations":true,"heading":"You may also like","show_vendor":false}},"1575306820345":{"type":"feature-columns","blocks":{"1575306820345-0":{"type":"text_block","settings":{"enable_image":true,"image":"shopify:\/\/shop_images\/battery2.jpg","title":"Rechargable Lithium Ion Batteries","text":"<p>All of our sabers are powered by long lasting lithium ion batteries. These batteries are protected by a charging circuit and every saber comes with a charging cord that you can plug in to any USB port for the utmost in convenient charging.<\/p>","button_label":"","button_link":""}},"1575306820345-1":{"type":"text_block","settings":{"enable_image":true,"image":"shopify:\/\/shop_images\/port2.jpg","title":"Recharge Port","text":"<p>Most of our sabers have a recharge port built right in at no extra cost. Just plug in your saber! There&#x27;s no need to take your saber apart!<\/p>","button_label":"","button_link":""}},"1575306820345-2":{"type":"text_block","settings":{"enable_image":true,"image":"shopify:\/\/shop_images\/rgb.jpg","title":"RGB Color Changing","text":"<p>With this feature, there is no need to choose a blade color because you can change it whenever you want! This is a standard feature on most sabers and takes alot of the guess work out of choosing the right color for a gift.<\/p>","button_label":"","button_link":""}},"1575306910877":{"type":"text_block","settings":{"enable_image":true,"image":"shopify:\/\/shop_images\/foc.jpg","title":"Flash on Clash","text":"<p>Every saber, even our stunt sabers without sound, have Flash on Clash! That means when the saber detects an impact, the saber will flash! It&#x27;s pretty cool if we do say so ourselves.<\/p>","button_label":"","button_link":""}},"1575306920928":{"type":"text_block","settings":{"enable_image":true,"image":"shopify:\/\/shop_images\/chassis3.jpg","title":"Internal Saber Chassis","text":"<p>Every Crimson Dawn Saber is built with a sturdy internal chassis to keep everything secure inside. It protects the parts inside the saber from moving and getting damaged from shocks and impacts.<\/p>","button_label":"","button_link":""}},"1575306924649":{"type":"text_block","settings":{"enable_image":true,"image":"shopify:\/\/shop_images\/blades3.jpg","title":"Polycarbonate Blades","text":"<p>All our sabers come with a 36 inch blade made of trans-white polycarbonate suitable for dueling! The tips of the blade are bolted in to prevent losing them. We also use blade film to ensure even illumination.<\/p>","button_label":"","button_link":""}},"1575306981009":{"type":"text_block","settings":{"enable_image":true,"image":"shopify:\/\/shop_images\/hilt.jpg","title":"Aircraft Aluminum Hilts","text":"<p>Our hilts are made from T6061 aluminum. This particular alloy is the most common grade of aluminum used in the aerospace industry. Even baffle systems in firearm sound suppressors are made from this alloy, so we are confident it will serve your saber well!<\/p>","button_label":"","button_link":""}},"1575306987289":{"type":"text_block","settings":{"enable_image":true,"image":"shopify:\/\/shop_images\/switch.jpg","title":"Metal Power Buttons","text":"<p>Our sabers feature stainless steel &quot;anti-vandal&quot; switches at no extra charge. They are recessed and not only look amazing, but are also extremely durable so they won&#x27;t break.<\/p>","button_label":"","button_link":""}},"1575306993086":{"type":"text_block","settings":{"enable_image":true,"image":"shopify:\/\/shop_images\/sound2.jpg","title":"Sound and Lighting Effects","text":"<p>Our EFX line of sabers come packed with sound and light features that are extremely easy to configure. Power up, power down, swing, impact, blaster block, Flash on Clash, lockup, color changing, multiple sound fonts, sleep mode, mute mode, volume control, etc, our sabers do it all and you won&#x27;t need any software to use these features!<\/p>","button_label":"","button_link":""}}},"block_order":["1575306820345-0","1575306820345-1","1575306820345-2","1575306910877","1575306920928","1575306924649","1575306981009","1575306987289","1575306993086"],"settings":{"title":"The Crimson Dawn Difference","align_text":"left"}},"1584137023713":{"type":"featured-blog","settings":{"title":"Crimson Dawn News","blog":"crimson-dawn-blog","post_limit":3,"blog_show_author":false,"blog_show_date":true,"show_view_all":true}},"article-template":{"type":"article-template","settings":{"blog_show_author":false,"blog_show_date":true,"show_share_buttons":true}},"blog-template":{"type":"blog-template","settings":{"layout":"list","blog_show_au